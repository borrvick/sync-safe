# .env.example — copy to .env and fill in values for local development.
# Never commit .env to git. All production secrets live in Railway env vars.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Django secret key — generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=replace-me-with-a-real-secret-key

# ---------------------------------------------------------------------------
# Database — defaults to SQLite for local dev
# ---------------------------------------------------------------------------

# Local dev: leave as sqlite (default). Production: Railway injects this automatically.
DATABASE_URL=sqlite:///db.sqlite3

# ---------------------------------------------------------------------------
# Django runtime
# ---------------------------------------------------------------------------

DEBUG=True
# Comma-separated list of allowed hostnames
ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.dev

# ---------------------------------------------------------------------------
# OAuth — leave blank to disable social login locally
# ---------------------------------------------------------------------------

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---------------------------------------------------------------------------
# Modal ML worker
# ---------------------------------------------------------------------------

# Base URL Django POSTs webhooks back to (Modal needs to reach this)
DJANGO_BASE_URL=http://localhost:8000

# Shared secret verified on every POST /api/webhooks/analysis-complete/
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
MODAL_WEBHOOK_SECRET=

# Set to True in production to dispatch jobs to Modal instead of the no-op stub
USE_MODAL_WORKER=False

# ---------------------------------------------------------------------------
# Rate limiting & caching
# ---------------------------------------------------------------------------

# Max analysis submissions per authenticated user (GPU is expensive)
ANALYZE_RATE_LIMIT=10/hour

# Seconds to cache complete/failed analysis results in the detail endpoint
ANALYSIS_CACHE_TTL_SECONDS=300

# ---------------------------------------------------------------------------
# CORS — deployed frontend origin (scheme + host, no trailing slash)
# Example: https://app.sync-safe.com
# ---------------------------------------------------------------------------

FRONTEND_URL=
