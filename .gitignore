# ---------------------------------------------------------------------------
# Local dev / testing infrastructure
# These directories are used during local development and algorithm tuning.
# They are intentionally excluded from the repository — delete the whole
# block below to nuke all local testing data when it's no longer needed:
#
#   local/tmp/   — audio + result JSON written by the app during dev runs
#   local/debug/ — full pipeline cache written by DEBUG_ANALYSIS=1
#   local/tools/ — one-off calibration and dev scripts (local only)
#   local/       — all of the above (entire local/ tree is excluded)
#   tests/fixtures/results/   — captured pipeline results (CAPTURE_RESULTS=1)
#   tests/fixtures/forensics/ — captured forensics fixtures (CAPTURE_OUTPUTS=1)
# ---------------------------------------------------------------------------
local/
tests/fixtures/results/*
tests/fixtures/forensics/*
!tests/fixtures/results/.gitkeep
!tests/fixtures/forensics/.gitkeep

# Secrets / credentials
cookies.txt
.env
.env.*

# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd

# Test / tooling cache
.pytest_cache/
.mypy_cache/
.ruff_cache/

# allin1 runtime cache (demucs stems + spectrograms written to CWD)
demix/
spec/

# macOS
.DS_Store

# Streamlit
.streamlit/secrets.toml

# Claude Code local memory (personal, not project source)
.claude/

# Generated / exported artifacts
*.html

# Daily pipeline logs (local only — rotated automatically at startup)
logs/
*.log
