  "transcription": [
    {
      "start": 14.06,
      "end": 17.81,
      "text": "Walking through the city lights"
    },
    {
      "start": 17.81,
      "end": 21.56,
      "text": "the night is calling out my name"
    },
    {
      "start": 21.56,
      "end": 25.31,
      "text": "I feel the rhythm in my bones"
    },
    {
      "start": 25.31,
      "end": 29.06,
      "text": "and nothing here will be the same"
    },
    {
      "start": 42.19,
      "end": 45.94,
      "text": "So turn it up and let it go"
    },
    {
      "start": 45.94,
      "end": 49.69,
      "text": "we only got tonight to burn"
    },
    {
      "start": 49.69,
      "end": 53.44,
      "text": "the whole world fades to radio"
    },
    {
      "start": 53.44,
      "end": 57.19,
      "text": "and every bridge we cross we learn"
    },
    {
      "start": 70.31,
      "end": 74.06,
      "text": "The echoes of a distant sound"
    },
    {
      "start": 74.06,
      "end": 77.81,
      "text": "keep pulling me back to the start"
    },
    {
      "start": 77.81,
      "end": 81.56,
      "text": "there is no map to where we are going"
    },
    {
      "start": 81.56,
      "end": 85.31,
      "text": "just trust the beat inside your heart"
    },
    {
      "start": 98.44,
      "end": 102.19,
      "text": "So turn it up and let it go"
    },
    {
      "start": 102.19,
      "end": 105.94,
      "text": "we only got tonight to burn"
    },
    {
      "start": 126.56,
      "end": 130.31,
      "text": "Every road leads somewhere new"
    },
    {
      "start": 130.31,
      "end": 134.06,
      "text": "every song has its own end"
    },
    {
      "start": 134.06,
      "end": 137.81,
      "text": "but this feeling right here between us"
    },
    {
      "start": 137.81,
      "end": 141.56,
      "text": "is something time can not bend"
    },
    {
      "start": 154.69,
      "end": 158.44,
      "text": "So turn it up and let it go"
    },
    {
      "start": 158.44,
